# Admin “Penny jar” contact threshold (optional). Ratio = downloads ÷ max(photos uploaded, 1).
# NEXT_PUBLIC_ADMIN_USAGE_MIN_DOWNLOADS=30
# NEXT_PUBLIC_ADMIN_USAGE_RATIO_THRESHOLD=8

# Next.js dev: `npm run dev` enables WATCHPACK_POLLING + webpack poll (see package.json / next.config.mjs).
# If you don’t need polling (repo outside iCloud): NEXT_DEV_POLL=0
# NEXT_DEV_POLL=0

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional server-only fallbacks (same values; useful if tooling strips NEXT_PUBLIC at build)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Vercel ---
# Project → Settings → Environment Variables: add every key your app needs.
# Enable for Production AND Preview. After adding/changing vars, Redeploy (new build).
# Minimum for this app: NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY,
# SUPABASE_SERVICE_ROLE_KEY (if you use service routes), GEMINI_API_KEY, GOOGLE_MAPS_API_KEY, ALLOWED_EMAIL_DOMAIN, etc.

# AI Tagging (Google AI Studio key — not Vertex)
GEMINI_API_KEY=
# Optional: exact model id if defaults 404 (see https://ai.google.dev/gemini-api/docs/models )
# GEMINI_VISION_MODEL=gemini-2.5-flash

# Google Maps Geocoding
GOOGLE_MAPS_API_KEY=

# Auth domain restriction
ALLOWED_EMAIL_DOMAIN=claritynw.com

# --- Google Chat (admin “Google Chat” button) — reliable path ---
# 1) Enable Google Chat API + Chat OAuth scopes on the same GCP project as your Google OAuth client.
# 2) Run migrations: 20260325120000_user_google_credentials.sql then
#    20260325140000_user_google_credentials_access_token.sql
# 3) SUPABASE_SERVICE_ROLE_KEY must be set (auth callback writes the vault with the service role).
# 4) Same Web OAuth client as Supabase → Auth → Google:
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# 5) 32-byte key, base64 (openssl rand -base64 32). Encrypts tokens at rest in Postgres.
GOOGLE_REFRESH_TOKEN_ENCRYPTION_KEY=
# 6) Deploy env vars to Vercel, then each admin: sign OUT and sign IN once so the callback stores
#    encrypted provider_token and/or provider_refresh_token (login uses access_type=offline).
# Optional: force consent once if Google never returns a refresh token:
# NEXT_PUBLIC_GOOGLE_OAUTH_PROMPT_CONSENT=1
